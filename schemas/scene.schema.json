{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/fmsm/scene.schema.json",
  "title": "FMSM Scene",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "scene",
    "source",
    "camera",
    "assembly_state",
    "output"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "scene": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "slug",
        "title",
        "description",
        "purpose",
        "instruction_markdown",
        "status",
        "tags"
      ],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "description": {
          "type": "string",
          "maxLength": 4000
        },
        "purpose": {
          "type": "string",
          "maxLength": 4000
        },
        "instruction_markdown": {
          "type": "string",
          "maxLength": 50000
        },
        "status": {
          "enum": [
            "draft",
            "review",
            "approved",
            "obsolete"
          ]
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "uniqueItems": true
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "document_data_file_id",
        "document_name",
        "captured_at_utc",
        "fusion_version"
      ],
      "properties": {
        "document_data_file_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "document_name": {
          "type": "string",
          "minLength": 1
        },
        "captured_at_utc": {
          "type": "string",
          "format": "date-time"
        },
        "fusion_version": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "camera": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "eye_cm",
        "target_cm",
        "up_vector",
        "extents_cm",
        "perspective_angle_rad",
        "is_fit_view"
      ],
      "properties": {
        "type": {
          "enum": [
            "orthographic",
            "perspective",
            "perspective_with_ortho_faces"
          ]
        },
        "eye_cm": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "type": "number"
          }
        },
        "target_cm": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "type": "number"
          }
        },
        "up_vector": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "type": "number"
          }
        },
        "extents_cm": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "width",
                "height"
              ],
              "properties": {
                "width": {
                  "type": "number",
                  "exclusiveMinimum": 0
                },
                "height": {
                  "type": "number",
                  "exclusiveMinimum": 0
                }
              }
            }
          ]
        },
        "perspective_angle_rad": {
          "type": [
            "number",
            "null"
          ],
          "exclusiveMinimum": 0
        },
        "is_fit_view": {
          "const": false
        }
      }
    },
    "assembly_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unlisted_occurrence_policy",
        "occurrences",
        "components"
      ],
      "properties": {
        "unlisted_occurrence_policy": {
          "const": "hide_and_warn"
        },
        "occurrences": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "occurrence_id",
              "label",
              "part_number",
              "visible",
              "transform_matrix_cm"
            ],
            "properties": {
              "occurrence_id": {
                "type": "string",
                "format": "uuid"
              },
              "label": {
                "type": "string",
                "minLength": 1
              },
              "part_number": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "visible": {
                "type": "boolean"
              },
              "transform_matrix_cm": {
                "type": "array",
                "minItems": 16,
                "maxItems": 16,
                "items": {
                  "type": "number"
                }
              }
            }
          }
        },
        "components": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "component_id",
              "label",
              "opacity"
            ],
            "properties": {
              "component_id": {
                "type": "string",
                "format": "uuid"
              },
              "label": {
                "type": "string",
                "minLength": 1
              },
              "opacity": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            }
          }
        }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "image_file",
        "thumbnail_file",
        "width_px",
        "height_px",
        "thumbnail_width_px",
        "thumbnail_height_px",
        "transparent_background",
        "anti_alias"
      ],
      "properties": {
        "image_file": {
          "type": "string",
          "pattern": "^assets/generated/[A-Za-z0-9._/-]+\\.png$"
        },
        "thumbnail_file": {
          "type": "string",
          "pattern": "^assets/thumbnails/[A-Za-z0-9._/-]+\\.png$"
        },
        "width_px": {
          "type": "integer",
          "minimum": 64,
          "maximum": 16384
        },
        "height_px": {
          "type": "integer",
          "minimum": 64,
          "maximum": 16384
        },
        "thumbnail_width_px": {
          "type": "integer",
          "minimum": 64,
          "maximum": 4096
        },
        "thumbnail_height_px": {
          "type": "integer",
          "minimum": 64,
          "maximum": 4096
        },
        "transparent_background": {
          "type": "boolean"
        },
        "anti_alias": {
          "type": "boolean"
        }
      }
    }
  }
}
